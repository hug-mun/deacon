FROM node:22-bookworm-slim

ENV NODE_ENV=production
WORKDIR /app

# PDF transcript extraction is part of the production worker, not the web image.
RUN apt-get update \
  && apt-get install -y --no-install-recommends poppler-utils \
  && rm -rf /var/lib/apt/lists/*

COPY package*.json ./
RUN npm ci --omit=dev

COPY scripts/process-media.mjs ./scripts/process-media.mjs

CMD ["node", "scripts/process-media.mjs"]
